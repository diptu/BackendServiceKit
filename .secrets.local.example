# =============================================================================
# act local secrets template
# =============================================================================
# Copy this file to .secrets.local and fill in real values.
# .secrets.local is listed in .gitignore — NEVER commit the filled-in copy.
#
#   cp .secrets.local.example .secrets.local
#
# These key names map directly to GitHub Actions secrets (${{ secrets.X }}).
# act reads them from this file and injects them into the runner container.
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED FOR ci.yml
# ---------------------------------------------------------------------------
# A GitHub Personal Access Token (PAT) or any non-empty dummy string.
# The CI workflow does not actually call the GitHub API, so a dummy value
# is sufficient for local test runs.
#
# Generate a real PAT at: https://github.com/settings/tokens
# Minimum scopes: repo (read)
GITHUB_TOKEN=ghp_replace_with_your_pat_or_leave_as_dummy_for_ci_only

# ---------------------------------------------------------------------------
# REQUIRED FOR cd.yml  (push to GHCR)
# ---------------------------------------------------------------------------
# The CD pipeline logs into GitHub Container Registry and pushes images.
# This requires a real PAT with the `packages:write` scope.
# Leave as dummy if you only intend to run ci-emulate (not cd-emulate).
#
# Minimum scopes: write:packages, read:packages, delete:packages
# GITHUB_TOKEN=ghp_replace_with_real_pat_with_packages_write_scope
