# act runtime configuration — loaded automatically by act from the repository root.
# Keeps per-command flags DRY; all `act` invocations in this project inherit these defaults.
#
# Runner image: catthehacker/ubuntu:act-latest
#   Full Ubuntu environment matching GitHub-hosted ubuntu-latest.
#   ~1.1 GB pull on first run; subsequent runs use the cached layer.
#   Includes Python, pip, Docker CLI, Node, curl, git — no extra setup needed.
#
# Architecture: linux/amd64
#   GitHub-hosted runners are always x86_64. Forcing linux/amd64 here ensures
#   binary parity on Apple Silicon (arm64) via Rosetta 2 / QEMU, and is a no-op
#   on native AMD64 Linux hosts.
#
# Pull policy: --pull=false
#   act's --pull flag is boolean: omitting it or setting it false means "use the local
#   image if it exists; Docker will pull automatically on first run when it is absent."
#   Set --pull (no value, i.e. true) to force a re-pull on every run when you want
#   to refresh the runner image after GitHub Actions patches it upstream.

--platform ubuntu-latest=catthehacker/ubuntu:act-latest
--container-architecture linux/amd64
--pull=false
--action-offline-mode
--rm
--artifact-server-path /tmp/act-artifacts
