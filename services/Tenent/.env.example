# Combined Tenent service environment variables
APP_NAME=nutratenant-tenent
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

DATABASE_URL=postgresql+asyncpg://neondb_owner:npg_28xTzodmkIUv@ep-solitary-lab-aoijafwv-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_SSL=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30

REDIS_URL=redis://localhost:6379/1
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=tenant.events

SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_AUTH_ENABLED=false

TENANT_PROVISIONING_BASE_URL=http://localhost:8003
TENANT_PROVISIONING_TIMEOUT=5.0

RATE_LIMIT_ENABLED=true
