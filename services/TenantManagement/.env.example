# Tenant Management Service — Environment Configuration
# Copy to .env and fill in your local values.
# Never commit .env to version control.

# ────────────────────────────────────────────────────
# Application
# ────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false

# ────────────────────────────────────────────────────
# Database (PostgreSQL via asyncpg)
# ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/nutratenant_tenant
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30

# ────────────────────────────────────────────────────
# Redis
# ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/1

# ────────────────────────────────────────────────────
# Messaging (RabbitMQ)
# ────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=tenant.events

# ────────────────────────────────────────────────────
# Security
# ────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# ────────────────────────────────────────────────────
# Rate Limiting
# ────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
DEFAULT_RATE_LIMIT=100/minute

# ────────────────────────────────────────────────────
# CORS
# ────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:8002"]

# ────────────────────────────────────────────────────
# Observability
# ────────────────────────────────────────────────────
ENABLE_METRICS=true
ENABLE_TRACING=true
OTLP_ENDPOINT=http://localhost:4317

# ────────────────────────────────────────────────────
# Health Checks
# ────────────────────────────────────────────────────
HEALTHCHECK_TIMEOUT_SECONDS=5
