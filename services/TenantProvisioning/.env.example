APP_NAME=nutratenant-tenant-provisioning
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/nutratenant_provisioning
DATABASE_SSL=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30

REDIS_URL=redis://localhost:6379/4

RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=tenant-provisioning.events

CELERY_BROKER_URL=amqp://guest:guest@localhost:5672/
CELERY_RESULT_BACKEND=redis://localhost:6379/6

SECRET_KEY=CHANGE_ME

# Downstream services
TENANT_LIFECYCLE_BASE_URL=http://localhost:8002
TENANT_LIFECYCLE_TIMEOUT=5.0

RATE_LIMIT_ENABLED=true
DEFAULT_RATE_LIMIT=100/minute

CORS_ALLOW_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:8001","http://localhost:8002"]

ENABLE_METRICS=true
ENABLE_TRACING=true
OTLP_ENDPOINT=http://localhost:4317

HEALTHCHECK_TIMEOUT_SECONDS=5
