APP_NAME=nutratenant-tenant-isolation
ENVIRONMENT=development
DEBUG=false
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/nutratenant_isolation
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30
DATABASE_SSL=false
REDIS_URL=redis://localhost:6379/5
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=tenant-isolation.events
SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_AUTH_ENABLED=false
TENANT_MANAGEMENT_BASE_URL=http://localhost:8001
TENANT_MANAGEMENT_TIMEOUT=5.0
RATE_LIMIT_ENABLED=true
DEFAULT_RATE_LIMIT=100/minute
ENABLE_METRICS=true
ENABLE_TRACING=false
OTLP_ENDPOINT=http://localhost:4317
HEALTHCHECK_TIMEOUT_SECONDS=5
