APP_NAME=nutratenant-tenant-lifecycle
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/nutratenant_lifecycle
DATABASE_SSL=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30

REDIS_URL=redis://localhost:6379/2

RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=tenant-lifecycle.events

SECRET_KEY=CHANGE_ME

# Downstream services
TENANT_MANAGEMENT_BASE_URL=http://localhost:8001
TENANT_MANAGEMENT_TIMEOUT=5.0

TENANT_PROVISIONING_BASE_URL=http://localhost:8003
TENANT_PROVISIONING_TIMEOUT=5.0

RATE_LIMIT_ENABLED=true
DEFAULT_RATE_LIMIT=100/minute

CORS_ALLOW_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:8001","http://127.0.0.1:8001"]

ENABLE_METRICS=true
ENABLE_TRACING=true
OTLP_ENDPOINT=http://localhost:4317
