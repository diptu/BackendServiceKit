APP_NAME=nutratenant-api-gateway
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

# Redis — DB 3 for response cache, DB 4 for Celery broker, DB 5 for Celery results
REDIS_URL=redis://localhost:6379/3
REDIS_TENANT_CACHE_TTL=300
REDIS_LIFECYCLE_CACHE_TTL=60

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=api-gateway.events
RABBITMQ_TENANT_EVENTS_EXCHANGE=tenant.events
RABBITMQ_TENANT_EVENTS_QUEUE=api-gateway.tenant-events

# Celery
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672/
CELERY_RESULT_BACKEND=redis://localhost:6379/5

# Upstream services
TENANT_MANAGEMENT_BASE_URL=http://localhost:8001
TENANT_LIFECYCLE_BASE_URL=http://localhost:8002
UPSTREAM_TIMEOUT=30.0

SECRET_KEY=CHANGE_ME

CORS_ALLOW_ORIGINS=["http://localhost:3000","http://localhost:8001","http://localhost:8002"]

ENABLE_METRICS=true
ENABLE_TRACING=true
OTLP_ENDPOINT=http://localhost:4317
